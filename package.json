{
  "name": "bob",
  "version": "0.0.4",
  "private": true,
  "description": "Bob Builder monorepo for planning, task execution, web, mobile, and execution services",
  "author": "Bob Team <sean@reedster.llc>",
  "license": "GPL-3.0",
  "homepage": "https://github.com/your-org/bob",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": "^10.19.0"
  },
  "packageManager": "pnpm@10.19.0",
  "scripts": {
    "build": "turbo run build",
    "clean": "git clean -xdf node_modules",
    "clean:workspaces": "turbo run clean",
    "auth:generate": "pnpm -F @bob/auth generate",
    "db:push": "turbo -F @bob/db push",
    "db:studio": "turbo -F @bob/db studio",
    "dev": "turbo watch dev --continue",
    "dev:web": "turbo watch dev -F @bob/blder...",
    "dev:mobile": "turbo watch dev -F @bob/mobile...",
    "dev:execution": "turbo watch dev -F @bob/execution...",
    "format": "turbo run format --continue -- --cache --cache-location .cache/.prettiercache",
    "format:fix": "turbo run format --continue -- --write --cache --cache-location .cache/.prettiercache",
    "lint": "turbo run lint --continue -- --cache --cache-location .cache/.eslintcache",
    "lint:fix": "turbo run lint --continue -- --fix --cache --cache-location .cache/.eslintcache",
    "lint:ws": "pnpm dlx sherif@latest",
    "typecheck": "turbo run typecheck",
    "ui-add": "turbo run ui-add",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "dev:mobile:local": "./scripts/dev-mobile.sh",
    "dev:gateway": "pnpm -F @bob/gateway dev",
    "dev:web:gateway": "turbo watch dev -F @bob/blder... -F @bob/gateway"
    ,
    "generate:work-item-rest": "pnpm exec tsx scripts/generate-work-item-rest-routes.ts"
  },
  "devDependencies": {
    "@bob/prettier-config": "workspace:*",
    "@turbo/gen": "^2.5.8",
    "concurrently": "^8.2.2",
    "dotenv-cli": "^10.0.0",
    "prettier": "catalog:",
    "turbo": "^2.5.8",
    "typescript": "catalog:"
  },
  "pnpm": {
    "overrides": {
      "@types/pg": "8.16.0",
      "node-gyp": "^10.0.0"
    },
    "onlyBuiltDependencies": [
      "node-pty",
      "@swc/core"
    ]
  },
  "prettier": "@bob/prettier-config",
  "dependencies": {
    "@types/dagre": "^0.7.54",
    "dagre": "^0.8.5"
  }
}
