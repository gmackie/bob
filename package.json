{
  "name": "gmacko",
  "private": true,
  "packageManager": "pnpm@10.12.1",
  "engines": { "node": ">=24.0.0" },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo watch dev --continue",
    "dev:web": "turbo watch dev --filter=@gmacko/web",
    "dev:mobile": "turbo watch dev --filter=@gmacko/mobile",
    "test": "turbo run test",
    "lint": "turbo run lint --continue",
    "typecheck": "turbo run typecheck",
    "dev:all": "bash scripts/dev.sh"
  },
  "pnpm": {
    "overrides": {
      "@types/pg": "8.16.0",
      "node-gyp": "^10.0.0",
      "react": "19.2.5",
      "react-dom": "19.2.5"
    },
    "onlyBuiltDependencies": [
      "@swc/core",
      "@tailwindcss/oxide",
      "electron",
      "esbuild",
      "node-pty",
      "sqlite3"
    ]
  },
  "devDependencies": {
    "turbo": "^2.8.0",
    "typescript": "^5.9.0"
  }
}
