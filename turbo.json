{
  "$schema": "https://turbo.build/schema.json",
  "globalEnv": [
    "APP_ENV",
    "API_URL",
    "GATEWAY_PUBLIC_URL",
    "NODE_ENV",
    "OODA_API_URL",
    "POSTHOG_HOST",
    "POSTHOG_KEY",
    "SENTRY_DSN",
    "EXPO_PUBLIC_*"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", ".next/**", ".cache/**"]
    },
    "dev": {
      "dependsOn": ["^build"],
      "persistent": true,
      "cache": false
    },
    "test": {},
    "lint": {},
    "typecheck": {}
  }
}
