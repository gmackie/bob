{
  "$schema": "https://turbo.build/schema.json",
  "globalEnv": [
    "APP_ENV",
    "API_URL",
    "GATEWAY_PUBLIC_URL",
    "NODE_ENV",
    "OODA_API_URL",
    "POSTHOG_HOST",
    "POSTHOG_KEY",
    "SENTRY_DSN",
    "EXPO_PUBLIC_*",
    "DATABASE_URL",
    "BOB_DB_DRIVER",
    "BOB_DB_PGLITE_DIR",
    "BOB_DB_MIGRATIONS_DIR",
    "BOB_AUTH_BYPASS",
    "BOB_AUTH_BYPASS_TOKEN",
    "BOB_AUTH_BYPASS_USER_ID",
    "REQUIRE_AUTH"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", ".next/**", ".cache/**"]
    },
    "dev": {
      "dependsOn": ["^build"],
      "persistent": true,
      "cache": false
    },
    "test": {},
    "lint": {},
    "typecheck": {}
  }
}
