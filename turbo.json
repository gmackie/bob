{
  "$schema": "https://turbo.build/schema.json",
  "globalEnv": [
    "APP_ENV",
    "API_URL",
    "GATEWAY_PUBLIC_URL",
    "NODE_ENV",
    "OODA_API_URL",
    "POSTHOG_HOST",
    "POSTHOG_KEY",
    "SENTRY_DSN",
    "STRIPE_PRICE_PREMIUM",
    "STRIPE_PRICE_PRO",
    "STRIPE_SECRET_KEY",
    "STRIPE_WEBHOOK_SECRET",
    "EXPO_PUBLIC_*",
    "DATABASE_URL",
    "BOB_DB_DRIVER",
    "BOB_DB_PGLITE_DIR",
    "BOB_DB_MIGRATIONS_DIR",
    "BOB_AUTH_BYPASS",
    "BOB_AUTH_BYPASS_TOKEN",
    "BOB_AUTH_BYPASS_USER_ID",
    "REQUIRE_AUTH",
    "BOB_API_KEY",
    "BOB_API_URL",
    "BOB_DEV_DIR",
    "BOB_EXECUTION_BACKEND",
    "BOB_PERSONAS_DIR",
    "BOB_REPOS_DIR",
    "BOB_RUNTIME_MIRROR_HOST",
    "BOB_RUNTIME_MIRROR_PORT",
    "BOB_TENANT_ID",
    "BOB_WORKSPACE_ID",
    "CODEX_MODEL",
    "CODEX_SANDBOX",
    "CURSOR_API_KEY",
    "DEFAULT_AGENT_TYPE",
    "DOCKER_ENV",
    "ELEVENLABS_AGENT_ID",
    "ELEVENLABS_API_KEY",
    "ENFORCE_USAGE_QUOTAS",
    "FG_API_TOKEN",
    "FG_API_URL",
    "FG_TIMEOUT_MS",
    "FORGEGRAPH_URL",
    "GATEWAY_URL",
    "GATEWAY_WS_URL",
    "GIT_TOKEN_ENCRYPTION_KEY",
    "HOME",
    "MAX_CONCURRENT",
    "NUDGE_SHARED_SECRET",
    "OPENCODE_API_KEY",
    "OPENCODE_SERVER_URL",
    "PULSE_API_KEY",
    "PULSE_API_URL",
    "USER"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", ".next/**", ".cache/**"]
    },
    "dev": {
      "dependsOn": ["^build"],
      "persistent": true,
      "cache": false
    },
    "test": {},
    "lint": {},
    "typecheck": {}
  }
}
