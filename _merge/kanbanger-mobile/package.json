{
  "name": "@linear-clone/mobile",
  "version": "0.0.0",
  "private": true,
  "main": "App.tsx",
  "scripts": {
    "dev": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "build": "echo 'Use EAS Build for production'",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "e2e": "maestro test .maestro/flows/",
    "e2e:smoke": "maestro test .maestro/flows/ --include-tags smoke",
    "e2e:pr": "maestro test .maestro/flows/ --include-tags pr",
    "e2e:home": "maestro test .maestro/flows/home.yaml",
    "e2e:navigation": "maestro test .maestro/flows/navigation.yaml",
    "e2e:tasks": "maestro test .maestro/flows/tasks.yaml",
    "e2e:projects": "maestro test .maestro/flows/projects.yaml",
    "e2e:agents": "maestro test .maestro/flows/agents.yaml",
    "e2e:setup-user": "npx tsx scripts/setup-e2e-user.ts",
    "build:simulator": "eas build --profile simulator --platform ios --local",
    "build:simulator:cloud": "eas build --profile simulator --platform ios"
  },
  "dependencies": {
    "@babel/runtime": "^7.28.4",
    "@expo/vector-icons": "^15.0.3",
    "@linear-clone/api": "workspace:*",
    "@linear-clone/i18n": "workspace:*",
    "@linear-clone/notifications": "workspace:*",
    "@linear-clone/shared": "workspace:*",
    "@linear-clone/storage": "workspace:*",
    "@linear-clone/store": "workspace:*",
    "@linear-clone/ui-native": "workspace:*",
    "@react-native-async-storage/async-storage": "^2.2.0",
    "@react-native-community/datetimepicker": "^8.4.4",
    "@react-navigation/bottom-tabs": "^7.9.0",
    "@react-navigation/native": "^7.1.26",
    "@react-navigation/native-stack": "^7.9.0",
    "@sentry/react-native": "^7.2.0",
    "@tanstack/react-query": "^5.62.7",
    "@trpc/client": "^11.0.0-rc.660",
    "@trpc/react-query": "^11.0.0-rc.660",
    "expo": "~54.0.31",
    "expo-auth-session": "~7.0.10",
    "expo-clipboard": "^8.0.8",
    "expo-dev-client": "~6.0.20",
    "expo-haptics": "^15.0.8",
    "expo-image-picker": "~17.0.10",
    "expo-localization": "~17.0.8",
    "expo-notifications": "~0.32.16",
    "expo-secure-store": "~15.0.8",
    "expo-splash-screen": "~31.0.13",
    "expo-status-bar": "~3.0.9",
    "expo-updates": "~29.0.16",
    "expo-web-browser": "~15.0.10",
    "posthog-react-native": "^3.3.11",
    "posthog-react-native-session-replay": "^1.2.3",
    "react": "19.1.0",
    "react-compiler-runtime": "^1.0.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "^2.30.0",
    "react-native-reanimated": "^4.1.6",
    "react-native-safe-area-context": "^5.6.2",
    "react-native-screens": "^4.16.0",
    "react-native-svg": "15.12.1",
    "superjson": "^2.2.2"
  },
  "devDependencies": {
    "@babel/core": "^7.26.0",
    "@linear-clone/eslint-config": "workspace:*",
    "@linear-clone/typescript-config": "workspace:*",
    "@types/node": "^22.10.5",
    "@types/react": "^19.1.17",
    "babel-plugin-module-resolver": "^5.0.2",
    "babel-preset-expo": "^54.0.9",
    "eslint": "^8.57.0",
    "metro-cache": "^0.83.3",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
