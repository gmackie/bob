{
  "name": "@bob/db",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./src/index.ts"
    },
    "./client": {
      "types": "./dist/client.d.ts",
      "default": "./src/client.ts"
    },
    "./client-neon": {
      "types": "./dist/client-neon.d.ts",
      "default": "./src/client-neon.ts"
    },
    "./client-pglite": {
      "types": "./dist/client-pglite.d.ts",
      "default": "./src/client-pglite.ts"
    },
    "./schema": {
      "types": "./dist/schema.d.ts",
      "default": "./src/schema.ts"
    }
  },
  "license": "MIT",
  "scripts": {
    "build": "tsc",
    "clean": "git clean -xdf .cache .turbo dist node_modules",
    "dev": "tsc",
    "format": "prettier --check . --ignore-path ../../.gitignore",
    "lint": "eslint --flag unstable_native_nodejs_ts_config",
    "push": "pnpm with-env drizzle-kit push",
    "migrate": "tsx src/migrate.ts",
    "migrate:dry": "tsx src/migrate.ts --dry-run",
    "migrate:bootstrap": "tsx src/migrate.ts --bootstrap",
    "studio": "pnpm with-env drizzle-kit studio",
    "test": "vitest run",
    "typecheck": "tsc --noEmit --emitDeclarationOnly false",
    "with-env": "dotenv -e ../../.env --"
  },
  "dependencies": {
    "@bob/agents": "workspace:*",
    "@bob/auth": "workspace:*",
    "@bob/chat": "workspace:*",
    "@bob/ci": "workspace:*",
    "@bob/cookies": "workspace:*",
    "@bob/git": "workspace:*",
    "@bob/notifications": "workspace:*",
    "@bob/projects": "workspace:*",
    "@bob/secrets": "workspace:*",
    "@bob/settings": "workspace:*",
    "@bob/tenancy": "workspace:*",
    "@bob/webhooks": "workspace:*",
    "@bob/work-items": "workspace:*",
    "@electric-sql/pglite": "^0.3.0",
    "@neondatabase/serverless": "^0.10.4",
    "drizzle-kit": "^0.31.5",
    "drizzle-orm": "^0.44.7",
    "drizzle-zod": "^0.8.3",
    "pg": "^8.17.1",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@bob/eslint-config": "workspace:*",
    "@bob/prettier-config": "workspace:*",
    "@bob/tsconfig": "workspace:*",
    "@types/pg": "8.16.0",
    "eslint": "catalog:",
    "prettier": "catalog:",
    "typescript": "catalog:",
    "vitest": "^4.0.0"
  },
  "prettier": "@bob/prettier-config"
}
