{
  "$schema": "https://oh-my-opencode.ai/schemas/config.json",
  "mcpServers": {
    "bob": {
      "command": "npx",
      "args": ["@bob/mcp-server"],
      "env": {
        "BOB_API_URL": "${env:BOB_API_URL}",
        "BOB_API_KEY": "${env:BOB_API_KEY}",
        "BOB_SESSION_ID": "${env:BOB_SESSION_ID}",
        "BOB_SECRET_BROKER_URL": "${env:BOB_SECRET_BROKER_URL}",
        "BOB_SECRET_BROKER_TOKEN": "${env:BOB_SECRET_BROKER_TOKEN}",
        "BOB_SESSION_SECRET_MANIFEST": "${env:BOB_SESSION_SECRET_MANIFEST}"
      }
    }
  },
  "skills": {
    "bob-workflow": {
      "name": "bob-workflow",
      "description": "Workflow and status reporting for Bob-managed sessions",
      "source": "@bob/agent-toolkit/oh-my-opencode/bob-workflow-skill"
    },
    "storybook-development": {
      "name": "storybook-development",
      "description": "State-first Storybook workflow for UI generation, state coverage, and prompt-driven iteration",
      "source": "@bob/agent-toolkit/oh-my-opencode/storybook-development-skill"
    }
  },
  "hooks": {
    "PostToolUse": {
      "bob-status-reporter": {
        "description": "Automatically report progress after significant tool operations",
        "enabled": false,
        "match": {
          "toolNames": ["Edit", "Write", "Bash"]
        },
        "action": "continue"
      }
    }
  }
}
