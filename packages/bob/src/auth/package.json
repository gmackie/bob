{
  "name": "@bob/auth",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./api-key": "./src/api-key.ts",
    "./session": "./src/session.ts",
    "./context": "./src/context.ts",
    "./middleware": "./src/middleware.ts",
    "./client": "./src/client.ts",
    "./schema": "./src/schema.ts",
    "./env": "./env.ts"
  },
  "license": "MIT",
  "scripts": {
    "clean": "git clean -xdf .cache .turbo dist node_modules",
    "format": "prettier --check . --ignore-path ../../.gitignore",
    "lint": "eslint --flag unstable_native_nodejs_ts_config",
    "generate": "dotenv -e ../../.env -- pnpx @better-auth/cli generate --config script/auth-cli.ts --output src/schema.ts",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@better-auth/expo": "catalog:",
    "@bob/db": "workspace:*",
    "@t3-oss/env-core": "^0.13.8",
    "better-auth": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@better-auth/cli": "catalog:",
    "@bob/eslint-config": "workspace:*",
    "@bob/prettier-config": "workspace:*",
    "@bob/tsconfig": "workspace:*",
    "eslint": "catalog:",
    "prettier": "catalog:",
    "typescript": "catalog:",
    "vitest": "^4.0.0"
  },
  "prettier": "@bob/prettier-config"
}
