{
  "name": "@bob/observability",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./src/index.ts"
    },
    "./config": {
      "types": "./dist/config.d.ts",
      "default": "./src/config.ts"
    },
    "./identity": {
      "types": "./dist/identity.d.ts",
      "default": "./src/identity.ts"
    },
    "./failures": {
      "types": "./dist/failures.d.ts",
      "default": "./src/failures.ts"
    },
    "./alerts": {
      "types": "./dist/alerts.d.ts",
      "default": "./src/alerts.ts"
    },
    "./node": {
      "types": "./dist/node.d.ts",
      "default": "./src/node.ts"
    }
  },
  "license": "MIT",
  "scripts": {
    "build": "tsc",
    "clean": "git clean -xdf .cache .turbo dist node_modules",
    "dev": "tsc",
    "format": "prettier --check . --ignore-path ../../.gitignore",
    "lint": "eslint --flag unstable_native_nodejs_ts_config",
    "test": "vitest run",
    "typecheck": "tsc --noEmit --emitDeclarationOnly false"
  },
  "dependencies": {
    "@sentry/node": "^10.53.1",
    "posthog-node": "^5.33.3"
  },
  "devDependencies": {
    "@bob/eslint-config": "workspace:*",
    "@bob/prettier-config": "workspace:*",
    "@bob/tsconfig": "workspace:*",
    "eslint": "catalog:",
    "prettier": "catalog:",
    "typescript": "catalog:",
    "vitest": "^4.0.0"
  },
  "prettier": "@bob/prettier-config"
}
