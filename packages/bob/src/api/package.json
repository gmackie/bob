{
  "name": "@bob/api",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/api/src/index.d.ts",
      "default": "./src/index.ts"
    },
    "./contracts/work-items-rest": {
      "types": "./dist/api/src/contracts/work-items-rest.d.ts",
      "default": "./src/contracts/work-items-rest.ts"
    },
    "./trpc": {
      "types": "./dist/api/src/trpc.d.ts",
      "default": "./src/trpc.ts"
    },
    "./router/*": {
      "types": "./dist/api/src/router/*.d.ts",
      "default": "./src/router/*.ts"
    },
    "./handlers/*": {
      "types": "./dist/api/src/handlers/*.d.ts",
      "default": "./src/handlers/*.ts"
    },
    "./openapi": {
      "types": "./dist/api/src/openapi.d.ts",
      "default": "./src/openapi.ts"
    },
    "./rpc-server": {
      "types": "./dist/api/src/rpc-server.d.ts",
      "default": "./src/rpc-server.ts"
    },
    "./rest-bridge": {
      "types": "./dist/api/src/rest-bridge.d.ts",
      "default": "./src/rest-bridge.ts"
    },
    "./runtime-layers": {
      "types": "./dist/api/src/runtime-layers.d.ts",
      "default": "./src/runtime-layers.ts"
    },
    "./services/webhooks/verify": {
      "types": "./dist/api/src/services/webhooks/verify.d.ts",
      "default": "./src/services/webhooks/verify.ts"
    },
    "./services/webhooks/processWebhook": {
      "types": "./dist/api/src/services/webhooks/processWebhook.d.ts",
      "default": "./src/services/webhooks/processWebhook.ts"
    },
    "./services/webhooks/processLinearWebhook": {
      "types": "./dist/api/src/services/webhooks/processLinearWebhook.d.ts",
      "default": "./src/services/webhooks/processLinearWebhook.ts"
    },
    "./services/forgegraph/pipelineOrchestrator": {
      "types": "./dist/api/src/services/forgegraph/pipelineOrchestrator.d.ts",
      "default": "./src/services/forgegraph/pipelineOrchestrator.ts"
    },
    "./services/git/providerConnectionService": {
      "types": "./dist/api/src/services/git/providerConnectionService.d.ts",
      "default": "./src/services/git/providerConnectionService.ts"
    },
    "./services/git/prService": {
      "types": "./dist/api/src/services/git/prService.d.ts",
      "default": "./src/services/git/prService.ts"
    },
    "./services/tasks/contextHeuristics": {
      "types": "./dist/api/src/services/tasks/contextHeuristics.d.ts",
      "default": "./src/services/tasks/contextHeuristics.ts"
    },
    "./services/tasks/taskAutoCreate": {
      "types": "./dist/api/src/services/tasks/taskAutoCreate.d.ts",
      "default": "./src/services/tasks/taskAutoCreate.ts"
    },
    "./services/push/pushService": {
      "types": "./dist/api/src/services/push/pushService.d.ts",
      "default": "./src/services/push/pushService.ts"
    },
    "./services/sessions/workflowStatusService": {
      "types": "./dist/api/src/services/sessions/workflowStatusService.d.ts",
      "default": "./src/services/sessions/workflowStatusService.ts"
    },
    "./services/opencode/opencodeClient": {
      "types": "./dist/api/src/services/opencode/opencodeClient.d.ts",
      "default": "./src/services/opencode/opencodeClient.ts"
    },
    "./services/forgegraph/eventReporter": {
      "types": "./dist/api/src/services/forgegraph/eventReporter.d.ts",
      "default": "./src/services/forgegraph/eventReporter.ts"
    },
    "./services/crypto/cookieVault": {
      "types": "./dist/api/src/services/crypto/cookieVault.d.ts",
      "default": "./src/services/crypto/cookieVault.ts"
    }
  },
  "license": "MIT",
  "scripts": {
    "build": "tsc",
    "clean": "git clean -xdf .cache .turbo dist node_modules",
    "dev": "tsc",
    "format": "prettier --check . --ignore-path ../../.gitignore",
    "lint": "eslint --flag unstable_native_nodejs_ts_config",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit --emitDeclarationOnly false"
  },
  "dependencies": {
    "@bob/auth": "workspace:*",
    "@bob/config": "workspace:*",
    "@bob/db": "workspace:*",
    "@bob/execution": "workspace:*",
    "@bob/execution-lib": "workspace:*",
    "@bob/telemetry": "workspace:*",
    "@bob/tenancy": "workspace:*",
    "@bob/work-items": "workspace:*",
    "@elevenlabs/client": "^0.13.0",
    "@gmacko/bob": "workspace:*",
    "@gmacko/core": "workspace:*",
    "@linear/sdk": "^83.0.0",
    "@trpc/server": "catalog:",
    "effect": "4.0.0-beta.43",
    "js-yaml": "^4.1.1",
    "superjson": "2.2.3",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@bob/eslint-config": "workspace:*",
    "@bob/prettier-config": "workspace:*",
    "@bob/tsconfig": "workspace:*",
    "@types/js-yaml": "^4.0.9",
    "@vitest/coverage-v8": "^4.0.0",
    "eslint": "catalog:",
    "openapi-types": "^12.1.3",
    "prettier": "catalog:",
    "typescript": "catalog:",
    "vitest": "^4.0.0"
  },
  "prettier": "@bob/prettier-config"
}
