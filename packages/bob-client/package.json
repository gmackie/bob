{
  "name": "@gmacko/bob-client",
  "version": "0.0.0",
  "private": true,
  "license": "MIT",
  "type": "module",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./openapi/bob.json": "./openapi/bob.json"
  },
  "scripts": {
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "generate": "pnpm -w run generate:openapi:bob && openapi-typescript openapi/bob.json -o src/schema.d.ts"
  },
  "dependencies": {
    "@gmacko/bob": "workspace:*",
    "@gmacko/core": "workspace:*",
    "effect": "4.0.0-beta.43",
    "openapi-fetch": "catalog:"
  },
  "devDependencies": {
    "@gmacko/tsconfig": "workspace:*",
    "@types/node": "catalog:",
    "openapi-typescript": "^7.13.0",
    "typescript": "catalog:",
    "vitest": "^4.0.0"
  }
}
