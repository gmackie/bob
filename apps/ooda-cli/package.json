{
  "name": "@gmacko/ooda-cli",
  "private": true,
  "license": "MIT",
  "type": "module",
  "bin": {
    "ooda": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "clean": "git clean -xdf .cache .turbo dist node_modules coverage",
    "dev": "tsx src/index.ts",
