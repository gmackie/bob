# Database (Hetzner Postgres, localhost when co-located)
DATABASE_URL=postgresql://bob:password@localhost:5432/bob

# Nudge secret (shared with blder.bot for /internal/nudge calls)
NUDGE_SHARED_SECRET=change-me-in-production

# Port (default 3002)
GATEWAY_PORT=3002

# Port (default 3002)
GATEWAY_PORT=3002

# Auth: better-auth session validation URL (blder.bot)
AUTH_BASE_URL=https://blder.bot

# Observability (optional — enable by setting DSN/key)
SENTRY_DSN=
POSTHOG_KEY=
POSTHOG_HOST=https://us.i.posthog.com
BOB_TENANT_ID=
SENTRY_TRACES_SAMPLE_RATE=0.1
