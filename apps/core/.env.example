# Public-facing base URL for OAuth redirects + better-auth's `baseURL`.
# In dev, http://localhost:3000 is fine. In production, set to the canonical
# origin (e.g. https://app.gmacko.example.com).
PUBLIC_BASE_URL=http://localhost:3000

# Better-auth: session cookie signing key. Required. 16+ chars.
# Generate via: `openssl rand -hex 32`
BETTER_AUTH_SECRET=

# @gmacko/secrets envelope encryption key. Required. 32+ chars.
# Generate via: `openssl rand -hex 32`
GMACKO_SECRET_ENCRYPTION_KEY=

# GitHub OAuth credentials. Optional in dev — without these, the GitHub
# button on /login is rendered but the underlying provider is skipped at
# better-auth init time.
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Anthropic Claude API key. Required only when GMACKO_AGENT_ADAPTER is unset
# or set to `claude-code` — the Claude Code CLI adapter shells out to the
# `claude` binary which reads this for authentication.
ANTHROPIC_API_KEY=

# Adapter selection: `claude-code` (real subprocess) or `mock`
# (deterministic in-memory adapter, useful for smoke tests + local dev
# without an Anthropic key). Defaults to `claude-code` if unset.
GMACKO_AGENT_ADAPTER=mock

# Realtime backend selector: `memory` (default), `redis`, or `ws-gateway`.
# `memory` uses an in-process PubSub — fine for single-instance dev/prod.
REALTIME_BACKEND=memory

# Override PGlite data directory. Defaults to `~/.gmacko/data` if unset.
# In CI / smoke tests, point to a tmp directory so the test owns its DB.
# PGLITE_DATA_DIR=

# Better-auth email + password provider toggle. Off by default — production
# wiring uses GitHub OAuth + the device-code pairing flow. Flip to "true"
# only when you need the /api/auth/sign-up/email + /sign-in/email endpoints
# (e.g. the apps/web smoke test).
# GMACKO_BETTER_AUTH_EMAIL_PASSWORD=false

# When the email + password provider is enabled, control whether sign-in
# requires the user to click a verification link. Default "true" (matches
# better-auth's secure default). Set to "false" in test environments so a
# sign-up + sign-in flow returns a session cookie immediately.
# GMACKO_BETTER_AUTH_REQUIRE_EMAIL_VERIFICATION=true
