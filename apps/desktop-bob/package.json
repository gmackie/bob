{
  "name": "@bob/desktop",
  "version": "0.0.1",
  "private": true,
  "license": "MIT",
  "main": "dist-electron/main.js",
  "productName": "Bob",
  "build": {
    "appId": "bot.blder.desktop",
    "productName": "Bob"
  },
  "scripts": {
    "dev": "pnpm run --parallel dev:bundle dev:electron",
    "dev:bundle": "tsdown --watch",
    "dev:electron": "node scripts/dev-electron.mjs",
    "build": "tsdown",
    "start": "node scripts/start-electron.mjs",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "electron": "40.6.0"
  },
  "devDependencies": {
    "@bob/tsconfig": "workspace:*",
    "@types/node": "catalog:",
    "tsdown": "^0.20.3",
    "typescript": "catalog:",
    "vitest": "^4.0.0"
  }
}
