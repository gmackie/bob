# Bob AI Agent Manager - Environment Variables

# =====================================================
# REQUIRED: Database (Neon Postgres)
# =====================================================
DATABASE_URL="postgresql://[user]:[password]@[endpoint].neon.tech/bob_dev?sslmode=require"

# =====================================================
# REQUIRED: Authentication (GitHub OAuth)
# =====================================================
AUTH_GITHUB_ID="your_github_oauth_app_id"
AUTH_GITHUB_SECRET="your_github_oauth_app_secret"
AUTH_SECRET="generate_with_openssl_rand_base64_32"

# =====================================================
# Bob-specific Configuration
# =====================================================
BOB_MODE="desktop"
REQUIRE_AUTH="false"
GATEWAY_URL="ws://localhost:3002"

# =====================================================
# Next.js Hosted (single-process) Deployment
# =====================================================
# Public origin for metadata and client-side WS defaulting.
NEXT_PUBLIC_SITE_URL="https://blder.bot"

# Optional explicit WS base (if you want to force a path/domain).
# If set, can be either "wss://ws.blder.bot" or "wss://ws.blder.bot/sessions".
# NEXT_PUBLIC_WS_BASE="wss://ws.blder.bot"

# Port for hosted Next+WS server. (Avoid reusing PORT which is used by legacy backend.)
NEXT_PORT="3100"

# Used by /api/config
APP_NAME="Bob"
ENABLE_GITHUB_AUTH="false"
JEFF_MODE="false"

# =====================================================
# OpenCode Server (Next.js API -> OpenCode server)
# =====================================================
OPENCODE_SERVER_URL="http://localhost:8080"
# OPENCODE_API_KEY="optional"

# =====================================================
# ElevenLabs Custom LLM Adapter (ElevenLabs -> Bob)
# =====================================================
# If set, `apps/nextjs/src/app/api/v1/chat/completions/route.ts` requires:
# Authorization: Bearer <token>
ELEVENLABS_CUSTOM_LLM_BEARER_TOKEN="change_me"

# =====================================================
# Tasks/Kanbanger Integration (tasks.gmac.io)
# =====================================================
KANBANGER_URL="https://tasks.gmac.io"
KANBANGER_API_KEY="your_kanbanger_api_key"

# =====================================================
# Gateway — ForgeGraph Integration
# =====================================================
# ForgeGraph CLI path (optional, defaults to ~/.forgegraph/bin/fg)
# FORGE_CLI_PATH="/home/mackieg/.forgegraph/bin/fg"

# =====================================================
# BizPulse Required Systems
# =====================================================
# Startup setup source: `pulse startup setup bob`
FG_API_URL="https://forgegraf.com"
FG_API_TOKEN="your_forgegraph_api_token"
CLOUDFLARE_ACCOUNT_ID="your_cloudflare_account_id"
CLOUDFLARE_API_TOKEN="your_cloudflare_api_token"
NEXT_PUBLIC_POSTHOG_HOST="https://us.i.posthog.com"
NEXT_PUBLIC_POSTHOG_KEY="your_posthog_project_key"
STRIPE_PRODUCT_ID="your_stripe_product_id"
QUICKBOOKS_REALM_ID="your_quickbooks_realm_id"
SENTRY_ORG="gmacko-ventures"
SENTRY_PROJECT="bob"
SENTRY_AUTH_TOKEN="your_sentry_auth_token"

# =====================================================
# Legacy Backend Configuration
# =====================================================
GITHUB_CLIENT_ID="same_as_AUTH_GITHUB_ID"
GITHUB_CLIENT_SECRET="same_as_AUTH_GITHUB_SECRET"
SESSION_SECRET="change_this_in_production"
NODE_ENV="development"
PORT="3001"
