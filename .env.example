# OODA
# Node.js does not expand ~. Use an absolute path or leave unset
# (defaults to $HOME/.ooda/threads/).
# OODA_STORAGE_ROOT=/Users/you/.ooda/threads/

# URL of the research-backend Python sidecar (FastAPI).
# Start with: pnpm dev:research
RESEARCH_API_URL=http://localhost:8000

# Paths to private Obsidian vaults. Optional -- features are disabled when unset.
PERSONAL_VAULT_PATH=
RESEARCH_VAULT_PATH=
PERSONAL_WEBSITE_PATH=

# Shared secret for runner↔server auth. Leave empty for dev (allows all).
OODA_RUNNER_SECRET=

# CORS origin for the Python research-backend sidecar.
OODA_CORS_ORIGIN=http://localhost:3000

# t3code execution backend for Bob task dispatch.
T3CODE_SERVER_URL=http://localhost:3773
T3CODE_PROJECT_ID=
T3CODE_MODEL_INSTANCE_ID=codex
T3CODE_MODEL=gpt-5
T3CODE_AUTH_TOKEN=
T3CODE_RUNTIME_MODE=full-access

# Optional OODA override when research threads should dispatch to a different t3 project.
OODA_T3CODE_SERVER_URL=
OODA_T3CODE_PROJECT_ID=
OODA_T3CODE_MODEL_INSTANCE_ID=
OODA_T3CODE_MODEL=
OODA_T3CODE_AUTH_TOKEN=
OODA_T3CODE_RUNTIME_MODE=

# Bob dashboard reporting for OODA runners. On gmacko-mini, set OODA_RUNNER_NAME
# to gmacko-mini so the node appears with macOS execution capacity in /nodes.
BOB_API_URL=http://localhost:3000
BOB_API_KEY=
BOB_WORKSPACE_ID=
OODA_RUNNER_NAME=gmacko-mini
BOB_MAX_CONCURRENT=4
