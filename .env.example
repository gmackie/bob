# OODA
# Node.js does not expand ~. Use an absolute path or leave unset
# (defaults to $HOME/.ooda/threads/).
# OODA_STORAGE_ROOT=/Users/you/.ooda/threads/

# URL of the research-backend Python sidecar (FastAPI).
# Start with: pnpm dev:research
RESEARCH_API_URL=http://localhost:8000

# Paths to private Obsidian vaults. Optional -- features are disabled when unset.
PERSONAL_VAULT_PATH=
RESEARCH_VAULT_PATH=
PERSONAL_WEBSITE_PATH=

# Shared secret for runner↔server auth. Leave empty for dev (allows all).
OODA_RUNNER_SECRET=

# CORS origin for the Python research-backend sidecar.
OODA_CORS_ORIGIN=http://localhost:3000
