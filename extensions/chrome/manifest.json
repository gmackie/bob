{
  "manifest_version": 3,
  "name": "BizPulse Cookie Bridge",
  "version": "1.0.0",
  "description": "Send browser cookies to BizPulse for authenticated agent sessions",
  "permissions": ["cookies", "activeTab", "storage"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "options_page": "options.html",
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  }
}
